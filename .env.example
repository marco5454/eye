VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: enable the shared-password gate.
# Leave empty (or unset) for unauthenticated local development.
# Set to any non-empty string to require visitors to enter the password
# before the app loads. The value is inlined into the JS bundle at build
# time, so this is a soft gate, not a real security boundary.
VITE_APP_PASSWORD=
